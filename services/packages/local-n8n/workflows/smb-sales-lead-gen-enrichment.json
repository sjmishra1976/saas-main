            },
            {
              "name": "x-service-activity-key",
              "value": "={{$env.SERVICE_ACTIVITY_INGEST_KEY || ''}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { eventType: 'workflow_execution', status: 'completed', workflowName: 'SMB Sales - Lead Generation & Enrichment', message: 'Sales workflow execution completed', leadCount: 1, processedAt: $now } }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "emit_service_activity",
      "name": "Emit Service Activity",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1540,
        560
      ],
      "continueOnFail": true
    }
  ],
