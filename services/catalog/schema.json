{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yourcompany.com/schemas/service-catalog.json",
  "title": "Service Catalog",
  "type": "object",
  "required": ["services"],
  "properties": {
    "services": {
      "type": "array",
      "items": { "$ref": "#/$defs/service" }
    }
  },
  "$defs": {
    "service": {
      "type": "object",
      "required": ["id", "name", "description", "packages"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "packages": {
          "type": "array",
          "items": { "$ref": "#/$defs/package" }
        }
      }
    },
    "package": {
      "type": "object",
      "required": ["id", "name", "image", "run"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "run": {
          "type": "object",
          "properties": {
            "ports": {
              "type": "array",
              "items": { "type": "string" }
            },
            "mode": {
              "type": "string",
              "enum": ["direct", "queue"]
            },
            "containerPort": {
              "type": "integer"
            },
            "redisImage": {
              "type": "string"
            },
            "env": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "volumes": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "docs": { "type": "string" }
      }
    }
  }
}
